# Telegram resume bot — copy to .env and fill in.
# After editing, run: source .env (or use systemd/launchd).

# Required — bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Required — allowlist of chat IDs (comma-separated).
# Find yours: send "/start" to your bot, then check
#   curl "https://api.telegram.org/bot${TOKEN}/getUpdates"
TELEGRAM_CHAT_IDS=

# Optional — path to executor.sh (default: ./executor.sh)
# CLAUDE_RESUME_EXECUTOR=$HOME/.claude-forge/telegram-resume/executor.sh

# Optional — long-poll timeout in seconds (default 25)
# TELEGRAM_POLL_TIMEOUT=25

# Optional — max sessions shown in /sessions (default 20)
# TELEGRAM_LIST_LIMIT=20

# Optional — log level (DEBUG, INFO, WARNING, ERROR)
# TELEGRAM_LOG_LEVEL=INFO

# Optional — Stop-hook only fires for sessions with at least this many turns (default 2)
# TELEGRAM_RESUME_NOTIFY_MIN_TURNS=2

# Optional — override claude binary path (default: claude in PATH)
# CLAUDE_BIN=/usr/local/bin/claude

# Optional — override tmux session name prefix (default: claude-)
# TMUX_SESSION_PREFIX=claude-
