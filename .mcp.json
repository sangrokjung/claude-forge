{
  "context7": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@upstash/context7-mcp@latest"]
  },
  "exa": {
    "type": "http",
    "url": "https://mcp.exa.ai/mcp"
  },
  "github": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-github"],
    "env": {
      "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
    }
  },
  "jina-reader": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "jina-mcp-tools"]
  }
}
