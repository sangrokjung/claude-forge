# Self-hosted 배포 환경변수 템플릿
# 복사 후 .env로 저장: cp .env.example .env

# 이미지 설정
REGISTRY=ghcr.io
IMAGE_NAME=your-org/your-app
IMAGE_TAG=latest

# 확장 (기본 2개, 필요 시 늘리기)
APP_REPLICAS=2

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_CONNECTION_STRING=Host=db.your-project.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=your-password

# 도메인 (nginx SSL용)
DOMAIN=yourdomain.com
